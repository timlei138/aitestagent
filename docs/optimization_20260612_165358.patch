+def _tools_summary(tools: list[Any]) -> str:
+    lines: list[str] = []
+    for t in tools:
+        desc = (getattr(t, "description", "") or "").strip()
+        args = getattr(t, "args", {}) or {}
+        arg_str = ", ".join(args.keys()) if args else "none"
+        lines.append(f"  {t.name}({arg_str}): {desc}")
+    return "\n".join(lines)
+
