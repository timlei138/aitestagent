+def _quick_resolve_app(text: str) -> tuple[str, str]:
+    lowered = text.lower()
+    for name, package in APP_NAME_MAP.items():
+        if name.lower() in lowered:
+            return package, name
+    match = re.search(r"\b[a-zA-Z][\w]*(?:\.[\w]+){2,}\b", text)
+    if match:
+        return match.group(0), ""
+    return "", ""
 
